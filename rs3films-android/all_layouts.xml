            android:textSize="11sp" android:textColor="#FF3C5F"/>

        <TextView android:id="@+id/tvPrice"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="14sp" android:textColor="#FFD166"
            android:textStyle="bold"/>

        <TextView android:id="@+id/tvSeats"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="10sp" android:textColor="#6B6B8A"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>


