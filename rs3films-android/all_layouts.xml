<!-- activity_home.xml                                          -->
<!-- ═══════════════════════════════════════════════════════════ -->
<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Welcome -->
        <TextView android:id="@+id/tvWelcome"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="22sp" android:textColor="@color/text_primary"
            android:textStyle="bold" android:layout_marginBottom="4dp"/>

        <!-- Coins bar -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="#1A1A0D"
            app:cardCornerRadius="16dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="20dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="⬡ MY COINS" android:textSize="11sp"
                    android:textColor="@color/gold" android:letterSpacing="0.2"/>
                <TextView android:id="@+id/tvCoins"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="40sp" android:textColor="@color/gold"
                    android:textStyle="bold"/>
                <TextView android:id="@+id/tvCoinValue"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="13sp" android:textColor="@color/text_muted"/>
                <TextView android:id="@+id/tvTotalReferrals"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="13sp" android:textColor="@color/cyan"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Movie card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="#13131F"
            app:cardCornerRadius="16dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="20dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🎬 NOW PROMOTING" android:textSize="11sp"
                    android:textColor="@color/accent" android:letterSpacing="0.2"
                    android:layout_marginBottom="8dp"/>
                <TextView android:id="@+id/tvMovieTitle"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="32sp" android:textColor="@color/text_primary"
                    android:textStyle="bold" android:fontFamily="serif"/>
                <TextView android:id="@+id/tvMovieTagline"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="13sp" android:textColor="@color/text_muted"
                    android:fontFamily="serif" android:layout_marginBottom="8dp"/>
                <TextView android:id="@+id/tvMovieInfo"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="13sp" android:textColor="@color/text_muted"/>
                <TextView android:id="@+id/tvRelease"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="13sp" android:textColor="@color/gold"
                    android:layout_marginTop="4dp" android:layout_marginBottom="16dp"/>
                <Button android:id="@+id/btnViewEvent"
                    android:layout_width="match_parent" android:layout_height="48dp"
                    android:text="View Event &amp; Book Tickets →"
                    android:backgroundTint="@color/accent"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Referral card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="#001A0D"
            app:cardCornerRadius="16dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="20dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🔗 REFER &amp; EARN" android:textSize="11sp"
                    android:textColor="@color/cyan" android:letterSpacing="0.2"
                    android:layout_marginBottom="8dp"/>
                <TextView android:id="@+id/tvShareHint"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="13sp" android:textColor="@color/text_muted"
                    android:layout_marginBottom="12dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Your Code:" android:textSize="12sp"
                    android:textColor="@color/text_muted"/>
                <TextView android:id="@+id/tvReferralCode"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="24sp" android:textColor="@color/cyan"
                    android:textStyle="bold" android:fontFamily="monospace"
                    android:layout_marginBottom="4dp"/>
                <TextView android:id="@+id/tvReferralLink"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="11sp" android:textColor="@color/text_muted"
                    android:layout_marginBottom="12dp"/>
                <Button android:id="@+id/btnCopyReferral"
                    android:layout_width="match_parent" android:layout_height="44dp"
                    android:text="Copy Referral Code 📋"
                    android:backgroundTint="@color/cyan"
                    android:textColor="@color/black"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Bottom buttons -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="12dp">
            <Button android:id="@+id/btnWallet"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="👛 Wallet"
                android:backgroundTint="#1A1A2E" android:layout_marginEnd="8dp"/>
            <Button android:id="@+id/btnMyTickets"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="🎟 My Tickets"
                android:backgroundTint="#1A1A2E"/>
        </LinearLayout>

        <Button android:id="@+id/btnLogout"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Logout"
            android:backgroundTint="#1A0A0A"
            android:textColor="@color/text_muted"/>

    </LinearLayout>
</ScrollView>


