<!-- ═══════════════════════════════════════════════════════════ -->
<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/bg_dark">

    <!-- Header -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:padding="16dp"
        android:background="#0F0F1A">
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical">
            <TextView android:id="@+id/tvFormat"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="16sp" android:textColor="#FF3C5F" android:textStyle="bold"/>
            <TextView android:id="@+id/tvShowtime"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="12sp" android:textColor="#6B6B8A"/>
        </LinearLayout>
        <TextView android:id="@+id/tvPricePerSeat"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="16sp" android:textColor="#FFD166" android:textStyle="bold"/>
    </LinearLayout>

    <!-- Screen indicator -->
    <TextView android:id="@+id/tvScreen"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:textSize="11sp" android:textColor="#6B6B8A"
        android:gravity="center" android:padding="8dp"
        android:background="#0A0A16"/>

    <!-- Seat grid -->
    <androidx.recyclerview.widget.RecyclerView android:id="@+id/rvSeats"
        android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:padding="12dp"/>

    <!-- Legend -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:padding="12dp"
        android:gravity="center" android:background="#0F0F1A">
        <TextView android:id="@+id/tvLegendAvailable"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="11sp" android:textColor="#6B6B8A" android:layout_marginEnd="16dp"/>
        <TextView android:id="@+id/tvLegendSelected"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="11sp" android:textColor="#FF3C5F" android:layout_marginEnd="16dp"/>
        <TextView android:id="@+id/tvLegendBooked"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="11sp" android:textColor="#444"/>
    </LinearLayout>

    <!-- Summary bar -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="16dp"
        android:background="#0F0F1A">

        <TextView android:id="@+id/tvSelectedSeats"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="13sp" android:textColor="#06D6A0"
            android:layout_marginBottom="8dp"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="8dp">
            <TextView android:id="@+id/tvCoinsAvailable"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:textSize="12sp" android:textColor="#FFD166"/>
            <Switch android:id="@+id/switchCoins"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Use Coins" android:textColor="#F0F0FF"
                android:thumbTint="#06D6A0" android:trackTint="#1E3A2A"/>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:id="@+id/tvTotalPrice"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="13sp" android:textColor="#6B6B8A"/>
                <TextView android:id="@+id/tvDiscount"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="12sp" android:textColor="#06D6A0"/>
                <TextView android:id="@+id/tvFinalPrice"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="18sp" android:textColor="#FFD166"
                    android:textStyle="bold"/>
            </LinearLayout>
            <Button android:id="@+id/btnConfirm"
                android:layout_width="wrap_content" android:layout_height="48dp"
                android:text="Continue →"
                android:backgroundTint="#FF3C5F"
                android:enabled="false"/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>


