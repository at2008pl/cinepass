<!-- activity_qr_ticket.xml                                     -->
<!-- ═══════════════════════════════════════════════════════════ -->
<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <ProgressBar android:id="@+id/progressBar"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_gravity="center" android:visibility="gone"/>

    <!-- Single ticket view -->
    <ScrollView android:id="@+id/layoutSingleTicket"
        android:layout_width="match_parent" android:layout_height="match_parent">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="24dp" android:gravity="center_horizontal">

            <!-- Ticket card -->
            <androidx.cardview.widget.CardView xmlns:app="http://schemas.android.com/apk/res-auto"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                app:cardBackgroundColor="#13131F" app:cardCornerRadius="24dp"
                android:layout_marginBottom="20dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Top purple section -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="24dp"
                        android:background="#1a0033" android:gravity="center">

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="RS³ FILMS PRESENTS"
                            android:textSize="11sp" android:textColor="#A080CC"
                            android:letterSpacing="0.2" android:layout_marginBottom="8dp"/>

                        <TextView android:id="@+id/tvMovieTitle"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textSize="32sp" android:textColor="#F0F0FF"
                            android:textStyle="bold" android:fontFamily="serif"
                            android:gravity="center"/>

                        <TextView android:id="@+id/tvTagline"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textSize="12sp" android:textColor="#A080CC"
                            android:fontFamily="serif" android:layout_marginBottom="12dp"/>

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="⚡ PRIORITY PASS"
                            android:textSize="12sp" android:textColor="#FF3C5F"
                            android:textStyle="bold"
                            android:background="#2A0A18"
                            android:paddingHorizontal="16dp" android:paddingVertical="6dp"/>
                    </LinearLayout>

                    <!-- Dashed separator -->
                    <View android:layout_width="match_parent" android:layout_height="2dp"
                        android:background="#1E1E32"/>

                    <!-- QR section -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="24dp"
                        android:gravity="center_horizontal">

                        <ImageView android:id="@+id/ivQrCode"
                            android:layout_width="200dp" android:layout_height="200dp"
                            android:background="#FFFFFF" android:padding="12dp"
                            android:layout_marginBottom="20dp"/>

                        <!-- Ticket details grid -->
                        <GridLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:columnCount="2" android:rowCount="3">

                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_columnWeight="1" android:orientation="vertical"
                                android:layout_margin="4dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="SEATS" android:textSize="10sp"
                                    android:textColor="#6B6B8A" android:letterSpacing="0.1"/>
                                <TextView android:id="@+id/tvSeats"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:textSize="14sp" android:textColor="#06D6A0"
                                    android:textStyle="bold"/>
                            </LinearLayout>

                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_columnWeight="1" android:orientation="vertical"
                                android:layout_margin="4dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="FORMAT" android:textSize="10sp"
                                    android:textColor="#6B6B8A" android:letterSpacing="0.1"/>
                                <TextView android:id="@+id/tvFormat"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:textSize="14sp" android:textColor="#FF3C5F"
                                    android:textStyle="bold"/>
                            </LinearLayout>

                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_columnWeight="1" android:orientation="vertical"
                                android:layout_margin="4dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="SHOWTIME" android:textSize="10sp"
                                    android:textColor="#6B6B8A" android:letterSpacing="0.1"/>
                                <TextView android:id="@+id/tvShowtime"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:textSize="13sp" android:textColor="#F0F0FF"/>
                            </LinearLayout>

                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_columnWeight="1" android:orientation="vertical"
                                android:layout_margin="4dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="VENUE" android:textSize="10sp"
                                    android:textColor="#6B6B8A" android:letterSpacing="0.1"/>
                                <TextView android:id="@+id/tvVenue"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:textSize="13sp" android:textColor="#F0F0FF"/>
                            </LinearLayout>

                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_columnWeight="1" android:orientation="vertical"
                                android:layout_margin="4dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="PAID" android:textSize="10sp"
                                    android:textColor="#6B6B8A" android:letterSpacing="0.1"/>
                                <TextView android:id="@+id/tvFinalPrice"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:textSize="16sp" android:textColor="#FFD166"
                                    android:textStyle="bold"/>
                            </LinearLayout>

                        </GridLayout>

                        <TextView android:id="@+id/tvSavings"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textSize="13sp" android:textColor="#06D6A0"
                            android:layout_marginTop="16dp" android:gravity="center"
                            android:visibility="gone"/>

                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <Button android:id="@+id/btnBackHome"
                android:layout_width="match_parent" android:layout_height="52dp"
                android:text="← Back to Home"
                android:backgroundTint="#13131F"
                android:textColor="#F0F0FF"/>

        </LinearLayout>
    </ScrollView>

    <!-- Ticket list view -->
    <LinearLayout android:id="@+id/layoutTicketList"
        android:layout_width="match_parent" android:layout_height="match_parent"
        android:orientation="vertical" android:visibility="gone">

        <TextView android:id="@+id/tvUpcomingHeader"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Upcoming Tickets" android:textSize="18sp"
            android:textColor="#F0F0FF" android:textStyle="bold"
            android:padding="16dp" android:visibility="gone"/>

        <TextView android:id="@+id/tvNoTickets"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="No tickets yet. Book your first ticket! 🎟"
            android:textColor="#6B6B8A" android:padding="32dp"
            android:layout_gravity="center" android:visibility="gone"/>

        <androidx.recyclerview.widget.RecyclerView android:id="@+id/rvTickets"
            android:layout_width="match_parent" android:layout_height="match_parent"
            android:padding="8dp"/>
    </LinearLayout>

</FrameLayout>


