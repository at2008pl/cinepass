<!-- activity_booking_confirm.xml                               -->
<!-- ═══════════════════════════════════════════════════════════ -->
<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/bg_dark">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="24dp">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Booking Summary" android:textSize="22sp"
            android:textColor="#F0F0FF" android:textStyle="bold"
            android:layout_marginBottom="24dp"/>

        <androidx.cardview.widget.CardView xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            app:cardBackgroundColor="#13131F" app:cardCornerRadius="16dp"
            android:layout_marginBottom="20dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="20dp">

                <TextView android:id="@+id/tvMovie"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="24sp" android:textColor="#F0F0FF"
                    android:textStyle="bold" android:fontFamily="serif"
                    android:layout_marginBottom="16dp"/>

                <!-- Detail rows -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Format"
                        android:textColor="#6B6B8A" android:textSize="13sp"/>
                    <TextView android:id="@+id/tvFormat"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="#FF3C5F" android:textStyle="bold" android:textSize="13sp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Showtime"
                        android:textColor="#6B6B8A" android:textSize="13sp"/>
                    <TextView android:id="@+id/tvShowtime"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="#F0F0FF" android:textSize="13sp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Seats"
                        android:textColor="#6B6B8A" android:textSize="13sp"/>
                    <TextView android:id="@+id/tvSeats"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="#06D6A0" android:textStyle="bold" android:textSize="13sp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="16dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Seat count"
                        android:textColor="#6B6B8A" android:textSize="13sp"/>
                    <TextView android:id="@+id/tvSeatCount"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="#F0F0FF" android:textSize="13sp"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#1E1E32" android:layout_marginBottom="12dp"/>

                <!-- Pricing -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="4dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Original Price"
                        android:textColor="#6B6B8A" android:textSize="13sp"/>
                    <TextView android:id="@+id/tvOriginalPrice"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="#F0F0FF" android:textSize="13sp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Coin Discount"
                        android:textColor="#6B6B8A" android:textSize="13sp"/>
                    <TextView android:id="@+id/tvCoinDiscount"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="#06D6A0" android:textSize="13sp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="YOU PAY"
                        android:textColor="#FFD166" android:textStyle="bold" android:textSize="16sp"/>
                    <TextView android:id="@+id/tvFinalPrice"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="#FFD166" android:textStyle="bold" android:textSize="20sp"/>
                </LinearLayout>

                <TextView android:id="@+id/tvCoinsUsed"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="11sp" android:textColor="#6B6B8A"
                    android:layout_marginTop="8dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <ProgressBar android:id="@+id/progressBar"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:visibility="gone" android:layout_gravity="center"
            android:layout_marginBottom="8dp"/>

        <Button android:id="@+id/btnConfirmPay"
            android:layout_width="match_parent" android:layout_height="56dp"
            android:text="✓ Confirm &amp; Book (Prototype — No Real Payment)"
            android:backgroundTint="#FF3C5F"
            android:textSize="14sp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="⚠️ Prototype: Payment is mocked. No real money charged."
            android:textSize="11sp" android:textColor="#6B6B8A"
            android:gravity="center" android:layout_gravity="center"
            android:layout_marginTop="8dp"/>

    </LinearLayout>
</ScrollView>


