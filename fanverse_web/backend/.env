# ── Database ────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:Animisha%402025@192.168.1.53:5432/Fanverse

# ── JWT ─────────────────────────────────────────────────
JWT_SECRET=!@#$%^&*()_++_)(*&^%$#@!)
JWT_EXPIRES_IN=7d

# ── Server ──────────────────────────────────────────────
PORT=6055
NODE_ENV=development
# Public base URL used to build media URLs (must be reachable by mobile clients)
MEDIA_BASE_URL=http://localhost:6055

# ── Cloudinary (for file uploads) ───────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── OTP (Twilio / MSG91 — for mobile app) ──────────────
OTP_SERVICE=mock
# OTP_TWILIO_SID=xxx
# OTP_TWILIO_TOKEN=xxx
# OTP_TWILIO_PHONE=+1xxx
