#include? "Config.local.xcconfig"

// Set your Apple Developer Team ID in Config.local.xcconfig (see Config.local.xcconfig.example).
TEAM_ID=

PRODUCT_NAME=Cinepass
PRODUCT_BUNDLE_IDENTIFIER=com.cinepass.app

CURRENT_PROJECT_VERSION=1
MARKETING_VERSION=1.0.0

FRAMEWORK_SEARCH_PATHS = $(inherited) $(SRCROOT)/../shared/build/xcode-frameworks/$(CONFIGURATION)/$(SDK_NAME)
OTHER_LDFLAGS = $(inherited) -framework ComposeApp
